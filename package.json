{
  "name": "flora-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "build:debug": "tsx esbuild.config.ts --debug",
    "watch": "tsx esbuild.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "tsx tests/visual/run.ts",
    "test:visual:update": "tsx tests/visual/run.ts --update",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@puppeteer/browsers": "^2.13.2",
    "@types/chrome": "^0.0.268",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.21.0",
    "jsdom": "^24.0.0",
    "msw": "^2.3.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^24.43.1",
    "tsx": "^4.11.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "vitest-chrome": "^0.1.0"
  }
}
